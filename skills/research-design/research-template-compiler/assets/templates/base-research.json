{
  "schema_version": "1.0",
  "template_id": "base-research",
  "description": "General evidence-driven research compiled from isolated cloze slots.",
  "extends": null,
  "locked_context": {
    "authorization_tier": "A0",
    "active_testing_approved": false,
    "allowed_actions": [
      "passive research",
      "local artifact review",
      "defensive analysis"
    ],
    "prohibited_actions": [
      "unauthorized active testing",
      "safety-review circumvention",
      "secret disclosure"
    ],
    "data_handling": "Store the minimum evidence necessary.",
    "output_audience": "requester",
    "terminology_profile": "domain-precise"
  },
  "slots": [
    {
      "slot_id": "SCOPE",
      "kind": "human",
      "prompt": "Define the research object, question, authorized sources, scope, non-goals, deliverable, and completion criteria.",
      "depends_on": [],
      "consumes": [],
      "produces": ["research_scope"],
      "required_keywords": ["research_object", "research_question", "authorized_sources", "scope", "non_goals", "completion_criteria"],
      "acceptance_criteria": ["The research object and source boundary are identifiable.", "The question is answerable.", "Scope and non-goals are explicit."],
      "max_candidates": 1,
      "stop_conditions": ["The research question is missing."],
      "escalation_conditions": ["Requested work exceeds authorization."],
      "exclusive_resources": []
    },
    {
      "slot_id": "CONTEXT",
      "kind": "evidence",
      "prompt": "Build a source-bound context model without proposing conclusions.",
      "depends_on": ["SCOPE"],
      "consumes": ["SCOPE.research_scope"],
      "produces": ["system_model", "source_index"],
      "required_keywords": ["known_facts", "source_quality", "missing_context"],
      "acceptance_criteria": ["Facts have locators.", "Unknowns are explicit.", "No hypothesis is presented as fact."],
      "max_candidates": 1,
      "stop_conditions": ["Required source artifacts are unavailable."],
      "escalation_conditions": ["A new external source or sensitive artifact is required."],
      "exclusive_resources": []
    },
    {
      "slot_id": "QUESTIONS",
      "kind": "generative",
      "prompt": "Decompose the scope into distinct answerable research questions.",
      "depends_on": ["CONTEXT"],
      "consumes": ["CONTEXT.system_model"],
      "produces": ["research_questions"],
      "required_keywords": ["question_clusters", "dependencies", "coverage_gaps"],
      "acceptance_criteria": ["Questions are non-duplicative.", "Each question has a testable completion condition."],
      "max_candidates": 5,
      "stop_conditions": ["The system model is insufficient."],
      "escalation_conditions": ["A question requires out-of-scope evidence."],
      "exclusive_resources": []
    },
    {
      "slot_id": "HYPOTHESES",
      "kind": "generative",
      "prompt": "Generate materially distinct, falsifiable hypotheses for the research questions.",
      "depends_on": ["CONTEXT", "QUESTIONS"],
      "consumes": ["CONTEXT.system_model", "QUESTIONS.research_questions"],
      "produces": ["hypotheses"],
      "required_keywords": ["candidate_hypotheses", "strongest_alternative", "falsification_conditions"],
      "acceptance_criteria": ["Every hypothesis is falsifiable.", "Alternatives are materially distinct.", "Assumptions are visible."],
      "max_candidates": 5,
      "stop_conditions": ["No answerable question exists."],
      "escalation_conditions": ["Testing a hypothesis requires new authorization."],
      "exclusive_resources": []
    },
    {
      "slot_id": "COUNTERMODELS",
      "kind": "generative",
      "prompt": "Construct counter-hypotheses, confounders, and benign explanations.",
      "depends_on": ["HYPOTHESES"],
      "consumes": ["HYPOTHESES.hypotheses"],
      "produces": ["countermodels"],
      "required_keywords": ["counter_hypotheses", "confounders", "disconfirming_observations"],
      "acceptance_criteria": ["Each material hypothesis has a countermodel.", "Confounders are testable where feasible."],
      "max_candidates": 5,
      "stop_conditions": ["Hypotheses are unavailable."],
      "escalation_conditions": ["A counter-test exceeds scope."],
      "exclusive_resources": []
    },
    {
      "slot_id": "METHODS",
      "kind": "derived",
      "prompt": "Derive a bounded method plan that distinguishes hypotheses from countermodels.",
      "depends_on": ["HYPOTHESES", "COUNTERMODELS"],
      "consumes": ["HYPOTHESES.hypotheses", "COUNTERMODELS.countermodels"],
      "produces": ["methods"],
      "required_keywords": ["method_candidates", "selection_rationale", "inconclusive_conditions"],
      "acceptance_criteria": ["Methods map to hypotheses.", "Controls and stopping criteria are explicit."],
      "max_candidates": 3,
      "stop_conditions": ["No method can distinguish the candidates."],
      "escalation_conditions": ["A method requires prohibited action or unavailable resources."],
      "exclusive_resources": []
    },
    {
      "slot_id": "EVIDENCE_PLAN",
      "kind": "derived",
      "prompt": "Define evidence, provenance, and acceptance requirements for the selected methods.",
      "depends_on": ["CONTEXT", "METHODS"],
      "consumes": ["CONTEXT.source_index", "METHODS.methods"],
      "produces": ["evidence_plan"],
      "required_keywords": ["primary_evidence", "counter_evidence", "provenance_fields"],
      "acceptance_criteria": ["Every planned claim has an evidence path.", "Counter-evidence is retained."],
      "max_candidates": 1,
      "stop_conditions": ["Evidence cannot be collected within scope."],
      "escalation_conditions": ["Sensitive evidence requires a new handling decision."],
      "exclusive_resources": []
    },
    {
      "slot_id": "TEMPLATE_CHALLENGE",
      "kind": "generative",
      "prompt": "Challenge the template, identify anchoring bias, and propose missing questions or a different decomposition.",
      "depends_on": ["CONTEXT", "HYPOTHESES", "METHODS"],
      "consumes": ["CONTEXT.system_model", "HYPOTHESES.hypotheses", "METHODS.methods"],
      "produces": ["template_challenge"],
      "required_keywords": ["questions_not_asked", "alternative_decomposition", "template_bias_risks"],
      "acceptance_criteria": ["At least one non-template perspective is considered.", "New-slot proposals identify scope impact."],
      "max_candidates": 3,
      "stop_conditions": [],
      "escalation_conditions": ["A proposed slot expands scope or capability."],
      "exclusive_resources": []
    },
    {
      "slot_id": "VERIFICATION",
      "kind": "verification",
      "prompt": "Independently verify the research frame, hypotheses, methods, evidence plan, and template challenge.",
      "depends_on": ["CONTEXT", "QUESTIONS", "HYPOTHESES", "COUNTERMODELS", "METHODS", "EVIDENCE_PLAN", "TEMPLATE_CHALLENGE"],
      "consumes": [
        "CONTEXT.system_model",
        "QUESTIONS.research_questions",
        "HYPOTHESES.hypotheses",
        "COUNTERMODELS.countermodels",
        "METHODS.methods",
        "EVIDENCE_PLAN.evidence_plan",
        "TEMPLATE_CHALLENGE.template_challenge"
      ],
      "produces": ["verified_packet"],
      "required_keywords": ["supported_claims", "contradicted_claims", "unresolved_claims", "limitations"],
      "acceptance_criteria": ["Reviewed slots are named.", "Verdicts cite evidence.", "Conflicts remain visible."],
      "max_candidates": 1,
      "stop_conditions": ["Required upstream proposals are missing."],
      "escalation_conditions": ["Verification discovers unsafe composition or scope drift."],
      "exclusive_resources": []
    },
    {
      "slot_id": "SYNTHESIS",
      "kind": "synthesis",
      "prompt": "Compile the verified packet into a complete research report and slot-coverage record.",
      "depends_on": ["VERIFICATION"],
      "consumes": ["VERIFICATION.verified_packet"],
      "produces": ["research_report", "slot_coverage"],
      "required_keywords": ["verified_conclusions", "evidence_links", "unresolved_slots", "limitations"],
      "acceptance_criteria": ["Every accepted claim maps to evidence.", "Missing and blocked slots are disclosed.", "No undeclared input is used."],
      "max_candidates": 1,
      "stop_conditions": ["Verification is non-terminal."],
      "escalation_conditions": ["The intended release audience changes."],
      "exclusive_resources": []
    }
  ],
  "synthesis_slot": "SYNTHESIS"
}
